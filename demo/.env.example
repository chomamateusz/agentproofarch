# Server
PORT=47100
APP_BASE_DOMAIN=localhost
APP_BASE_URL=http://localhost:47100
BETTER_AUTH_SECRET=change-me-to-32-random-chars-in-prod
SECURE_COOKIES=false

# Database — the ONLY place the platform differs:
#   local/Docker : DB_DRIVER=node-postgres
#   Vercel+Neon  : DB_DRIVER=neon-http
# Default follows the platform: neon-http when VERCEL is set (Vercel injects
# VERCEL=1 at build and runtime), node-postgres otherwise. Set it explicitly to
# override. Applies to both the server (env.ts) and build-time migrations.
DB_DRIVER=node-postgres
DATABASE_URL=postgresql://agentproofarch:agentproofarch@localhost:47542/agentproofarch

# Where the built SPA lives (served by the same process)
WEB_DIST_DIR=dist/web

# Observability — ALL optional. Unset = OTel facade no-ops, zero network.
#   Server: registers an OTLP tracer only when an endpoint is set.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# OTEL_SERVICE_NAME=agentproofarch-server
#   Web (Vite VITE_ prefix): Sentry initialises only when a DSN is set.
# VITE_SENTRY_DSN=
