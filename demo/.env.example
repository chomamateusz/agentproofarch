# Server
PORT=47100
APP_BASE_DOMAIN=localhost
APP_BASE_URL=http://localhost:47100
# Refused outside local dev: once deployed (VERCEL set, or SECURE_COOKIES=true)
# the schema rejects the dev-only sentinel default — override with real entropy.
BETTER_AUTH_SECRET=change-me-to-32-random-chars-in-prod
# Off only in local dev. Turning it on marks the process as "deployed", so the
# schema then also requires a non-sentinel BETTER_AUTH_SECRET. Required in prod.
SECURE_COOKIES=false
# Auth rate limiting (Better Auth). `off` only in test harnesses (e2e drives
# many sign-ins from one bucket); leave `on` everywhere else.
AUTH_RATE_LIMIT=on

# Injected by Vercel into every deployment (do NOT set locally) — previews
# derive their base URL and trusted auth origin from these.
# VERCEL_URL=
# VERCEL_BRANCH_URL=

# Build attestation surfaced by /api/health*. Vendor-neutral: the platform entry
# (api/index.ts) maps Vercel's VERCEL_GIT_COMMIT_SHA into it, so no other code
# knows the vendor name. Self-host sets it directly (e.g. a Docker build arg);
# unset locally it reports as "unknown". post-deploy smoke asserts it == deploy SHA.
# APP_COMMIT_SHA=

# Database — the ONLY place the platform differs:
#   local/Docker : DB_DRIVER=node-postgres
#   Vercel+Neon  : DB_DRIVER=neon-http
# Default follows the platform: neon-http when VERCEL is set (Vercel injects
# VERCEL=1 at build and runtime), node-postgres otherwise. Set it explicitly to
# override. Applies to both the server (env.ts) and build-time migrations.
DB_DRIVER=node-postgres
DATABASE_URL=postgresql://agentproofarch:agentproofarch@localhost:47542/agentproofarch

# Where the built SPA lives (served by the same process)
WEB_DIST_DIR=dist/web

# Email (US-026 magic link + any transactional mail). Selected by EMAIL_TRANSPORT
# in the composition root, like DOMAIN_PROVISIONER. There is NO separate dev
# transport: dev/e2e/CI run the REAL smtp adapter pointed at a local Mailpit
# (docker-compose.dev.yml) — a self-hosted MailTrap that captures every send
# instead of delivering. Read the captured magic link from the Mailpit UI/API
# (http://localhost:47980), not an in-app route.
#   smtp (default) — any RFC SMTP relay. Defaults point at the dev Mailpit
#                    (SMTP_HOST=localhost, SMTP_PORT=47925); an open local relay
#                    needs no SMTP_USER/SMTP_PASS. Amazon SES SMTP creds work as-is
#                    (SMTP_HOST=email-smtp.<region>.amazonaws.com, the SES SMTP
#                    user/pass, SMTP_PORT=587, SMTP_SECURE=false for STARTTLS).
#   ses            — Amazon SES directly over the SESv2 HTTP API (an access key
#                    instead of an open SMTP port); needs the AWS_* block below.
#                    Fails fast if selected without it (composition error).
EMAIL_TRANSPORT=smtp
# EMAIL_FROM=Agentproofarch <no-reply@example.com>
# Dev/CI Mailpit defaults (leave as-is locally); a real relay overrides these.
SMTP_HOST=localhost
SMTP_PORT=47925
SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# Amazon SES direct (EMAIL_TRANSPORT=ses) — standard AWS credential env names,
# read only by the SES email adapter. The From address must be a verified SES
# identity in this region.
# AWS_REGION=eu-central-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# Google social sign-in (FR-26). Wired ONLY when BOTH are present (the same
# present-both-or-dormant gating as SENTRY_DSN); the login page hides its Google
# button otherwise. Redirect URI: {APP_BASE_URL}/api/auth/callback/google.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Docker self-host (docker-compose.prod.yml, US-022). These extra keys are read
# by compose interpolation and the container entrypoint, not by the app config
# schema. For a real deployment behind Caddy TLS, also set (above):
#   APP_BASE_URL=https://app.example.com   APP_BASE_DOMAIN=example.com
#   SECURE_COOKIES=true   BETTER_AUTH_SECRET=<32+ random chars>   AUTH_RATE_LIMIT=on
# In compose the app's DATABASE_URL is overridden to the `postgres` service
# (postgresql://<user>:<pass>@postgres:5432/<db>), so the localhost DATABASE_URL
# above only applies to bare `npm` dev.
#   POSTGRES_USER/PASSWORD/DB — credentials for the postgres sidecar + the URL.
POSTGRES_USER=agentproofarch
POSTGRES_PASSWORD=agentproofarch
POSTGRES_DB=agentproofarch
#   APP_PORT — host port the app publishes (high port; behind Caddy you may drop it).
#   Changing APP_PORT means changing APP_BASE_URL's port too — Better Auth
#   rejects sign-ins whose Origin does not match APP_BASE_URL (403 invalid origin).
APP_PORT=47100
#   CADDY_HTTP_PORT/HTTPS_PORT — host ports for the `edge` profile's Caddy. The
#   80/443 defaults are what on-demand TLS/ACME needs; remap only for local tests.
# CADDY_HTTP_PORT=80
# CADDY_HTTPS_PORT=443
#   SEED_ON_START — entrypoint seeds the idempotent demo data when `true`
#   (CI smoke + local demos); leave unset in production.
# SEED_ON_START=true

# Self-host custom domains + TLS (US-021). Set ONLY on the Docker self-host
# target (docker-compose.yml wires them); unset on Vercel and in local dev.
#   INTERNAL_PORT       — private port the domain-check control plane binds. In
#                         compose it is reachable only on the container network
#                         (Caddy's on_demand_tls `ask`), never published to the
#                         host. Unset here → the internal endpoint does not start.
#   DOMAIN_PROVISIONER  — caddy on self-host (on-demand TLS + DNS check), noop
#                         (default) in dev and on Vercel.
#   SELF_HOST_TARGET_*  — the public CNAME/IP tenants point a custom domain at;
#                         the caddy DomainPort's check verifies DNS resolves here.
#                         Set one, not both.
# INTERNAL_PORT=47101
DOMAIN_PROVISIONER=noop
# SELF_HOST_TARGET_CNAME=apps.example.com
# SELF_HOST_TARGET_IP=203.0.113.10

# C4 backfills (§Backfills). On self-host the batch endpoint rides the
# network-isolated INTERNAL_PORT app and needs no secret. On Vercel there is no
# private port, so the same batch runs behind an authenticated route on the
# public app gated by this strong shared secret (min 24 chars). Set it ONLY in
# the platform env (human-owned), never in dev — unset → the public route stays
# unmounted, so a deploy without it cannot expose the surface.
# INTERNAL_BACKFILL_SECRET=

# Observability — ALL optional. Unset = OTel facade no-ops, zero network.
#   Server: registers an OTLP tracer when either endpoint is set (the
#   traces-specific one overrides the general one for spans).
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://localhost:4318/v1/traces
# OTEL_SERVICE_NAME=agentproofarch-server
#   Server Sentry: the error sink initialises only when a DSN is set. Absent =
#   clean no-op — no client, no network. Errors are captured through the single
#   app.onError seam only; tracing stays on OTel (no Sentry auto-instrumentation).
# SENTRY_DSN=
#   Web (Vite VITE_ prefix): Sentry initialises only when a DSN is set.
# VITE_SENTRY_DSN=
