{
  "name": "agentproofarch",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Agent-first, strictly layered full-stack TypeScript foundation for multi-tenant SaaS",
  "imports": {
    "#core/*": "./core/*",
    "#adapters/*": "./adapters/*"
  },
  "scripts": {
    "dev:server": "tsx watch apps/server/src/entry.node.ts",
    "dev:web": "vite --config apps/web/vite.config.ts",
    "build": "npm run build:web && npm run typecheck",
    "build:web": "vite build --config apps/web/vite.config.ts",
    "vercel-build": "npm run db:migrate && npm run build",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:integration": "VITEST_INTEGRATION=1 vitest run --project integration --no-file-parallelism",
    "typecheck": "tsc --noEmit",
    "typecheck:islands": "tsc --noEmit -p tsconfig.islands.json",
    "lint": "eslint .",
    "depcruise": "depcruise core adapters apps scripts api",
    "knip": "knip",
    "doc-lint": "tsx scripts/doc-lint.ts",
    "check": "npm run typecheck && npm run typecheck:islands && npm run lint && npm run lock-lint && npm run depcruise && npm run knip && npm run doc-lint && npm run test:coverage",
    "db:up": "docker compose -f docker-compose.dev.yml up -d",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx adapters/db/migrate.ts",
    "db:seed": "tsx adapters/db/seed.ts",
    "cli": "tsx apps/cli/src/main.ts",
    "new:resource": "tsx scripts/new-resource.ts",
    "new:island": "tsx scripts/new-island.ts",
    "smoke": "tsx scripts/smoke.ts",
    "e2e": "playwright test",
    "smoke:remote": "tsx scripts/smoke-remote.ts",
    "lock-lint": "npx -y npm@10 ls --all --package-lock-only >/dev/null"
  },
  "engines": {
    "node": "22.x",
    "npm": ">=10 <11"
  },
  "packageManager": "npm@10.9.2",
  "dependencies": {
    "@aws-sdk/client-sesv2": "^3.1091.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@hono/node-server": "^1.17.1",
    "@mui/material": "^9.2.0",
    "@neondatabase/serverless": "^1.0.1",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-trace-otlp-http": "^0.220.0",
    "@opentelemetry/resources": "^2.9.0",
    "@opentelemetry/sdk-trace-node": "^2.9.0",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "@sentry/node": "^10.67.0",
    "@sentry/react": "^10.65.0",
    "@tanstack/query-core": "^5.83.0",
    "@tanstack/react-query": "^5.83.0",
    "@tanstack/react-router": "^1.130.2",
    "@xstate/store": "^4.2.1",
    "better-auth": "^1.3.4",
    "commander": "^14.0.0",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.8.5",
    "nodemailer": "^9.0.3",
    "pg": "^8.16.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "xstate": "^5.32.5",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "@opentelemetry/core": "^2.9.0",
    "@opentelemetry/sdk-trace-base": "^2.9.0",
    "@playwright/test": "^1.61.1",
    "@tanstack/eslint-plugin-query": "^5.101.2",
    "@tanstack/react-query-devtools": "^5.101.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.0.14",
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "^8.15.4",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^3.2.7",
    "dependency-cruiser": "^16.10.3",
    "drizzle-kit": "^0.31.4",
    "eslint": "^9.31.0",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-boundaries": "^5.0.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-compiler": "^19.1.0-rc.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jsdom": "^29.1.1",
    "knip": "^6.27.0",
    "msw": "^2.15.0",
    "otplib": "^13.4.1",
    "pixelmatch": "^7.2.0",
    "playwright-core": "^1.61.1",
    "pngjs": "^7.0.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.37.0",
    "vite": "^7.0.5",
    "vitest": "^3.2.4"
  }
}
