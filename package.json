{
  "name": "agentproofarch",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Agent-first, strictly layered full-stack TypeScript foundation for multi-tenant SaaS",
  "bin": {
    "agentproofarch": "./apps/cli/bin.js"
  },
  "scripts": {
    "dev:server": "tsx watch apps/server/src/entry.node.ts",
    "dev:web": "vite --config apps/web/vite.config.ts",
    "build": "npm run build:web && npm run typecheck",
    "build:web": "vite build --config apps/web/vite.config.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "depcruise": "depcruise core adapters apps",
    "check": "npm run typecheck && npm run lint && npm run depcruise && npm run test",
    "db:up": "docker compose -f docker-compose.dev.yml up -d",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx adapters/db/migrate.ts",
    "db:seed": "tsx adapters/db/seed.ts",
    "cli": "tsx apps/cli/src/main.ts"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@hono/node-server": "^1.17.1",
    "@mui/material": "^9.2.0",
    "@neondatabase/serverless": "^1.0.1",
    "@tanstack/query-core": "^5.83.0",
    "@tanstack/react-query": "^5.83.0",
    "@tanstack/react-router": "^1.130.2",
    "better-auth": "^1.3.4",
    "commander": "^14.0.0",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.8.5",
    "pg": "^8.16.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^24.0.14",
    "@types/pg": "^8.15.4",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.7.0",
    "dependency-cruiser": "^16.10.3",
    "drizzle-kit": "^0.31.4",
    "eslint": "^9.31.0",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-boundaries": "^5.0.1",
    "playwright-core": "^1.61.1",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.37.0",
    "vite": "^7.0.5",
    "vitest": "^3.2.4"
  }
}
